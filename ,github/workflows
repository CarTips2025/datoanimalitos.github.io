name: 🔧 PRUEBA - ¿Funciona GitHub Actions?

on:
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - name: 📝 Crear archivo de prueba
        run: |
          echo "Test: $(date)" > test.txt
          echo "✅ Si ves este mensaje, GitHub Actions funciona"
          
      - name: 📤 Subir archivo de prueba
        run: |
          git config --global user.name "Test Bot"
          git config --global user.email "test@bot.com"
          git add test.txt
          git commit -m "Test de GitHub Actions"
          git push
