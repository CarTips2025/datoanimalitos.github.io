name: 🤖 Actualización Automática de Resultados

on:
  schedule:
    - cron: '0 3 * * *'  # 11:00 PM hora Venezuela (3:00 UTC)
  workflow_dispatch:  # Permite ejecución manual

permissions:
  contents: write

jobs:
  actualizar:
    runs-on: ubuntu-latest
    steps:
      - name: 📥 Clonar repositorio
        uses: actions/checkout@v4

      - name: 🔧 Configurar Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: 📦 Instalar dependencias
        run: |
          mkdir -p scripts
          cd scripts
          echo '{"dependencies":{"node-fetch":"^3.3.2"}}' > package.json
          npm install

      - name: 🔍 Obtener resultados de la API
        id: obtener
        run: node scripts/obtener_de_api.js
        continue-on-error: true

      - name: 📤 Actualizar archivos JSON
        if: success()
        run: |
          if [ -f temp_resultados/nuevos.json ]; then
            NUEVOS=$(cat temp_resultados/nuevos.json)
            
            if [ -f data/guacharo.json ]; then
              node -e "
                const fs = require('fs');
                const nuevos = JSON.parse(process.env.NUEVOS);
                const actual = JSON.parse(fs.readFileSync('data/guacharo.json'));
                const [diaViejo, diaMedio, diaReciente] = actual.resultados;
                actual.resultados = [diaMedio, diaReciente, nuevos.guacharo];
                actual.fecha_actualizacion = new Date().toISOString();
                fs.writeFileSync('data/guacharo.json', JSON.stringify(actual, null, 2));
              "
              echo "✅ guacharo.json actualizado"
            fi
          fi

      - name: 📤 Commit y push
        run: |
          git config --global user.name "Dr. Animalitos Bot"
          git config --global user.email "bot@datoanimalitos.github.io"
          git add data/*.json
          git diff --quiet && git diff --staged --quiet || git commit -m "🤖 Actualización automática $(date +'%d/%m/%Y')"
          git push
name: 🤖 Actualización Automática de Resultados

on:
  schedule:
    - cron: '0 3 * * *'
  workflow_dispatch:

permissions:
  contents: write

jobs:
  actualizar:
    runs-on: ubuntu-latest
    steps:
      - name: 📥 Clonar repositorio
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.PAT_TOKEN }}

      - name: 🔧 Configurar Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: 📦 Instalar dependencias
        run: |
          cd scripts
          npm init -y
          npm install node-fetch@3.3.2

      - name: 🔍 Obtener resultados de la API
        run: node scripts/obtener_de_api.js
        env:
          NODE_OPTIONS: --experimental-fetch

      - name: 📤 Commit y push
        run: |
          git config --global user.name "Dr. Animalitos Bot"
          git config --global user.email "bot@datoanimalitos.github.io"
          git add data/*.json temp_resultados/
          if git diff --cached --quiet; then
            echo "📭 Sin cambios"
          else
            git commit -m "🤖 Actualización $(date)"
            git push
          fi
